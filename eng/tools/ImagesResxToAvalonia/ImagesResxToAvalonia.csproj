<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Development tool for the Avalonia port: generates the same-named Avalonia Images
         API from GitUI's file-backed WinForms Images.resx entries. -->
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <UseWindowsForms>false</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="$(RepoRoot)\CommonAssemblyInfo.cs" />
  </ItemGroup>

</Project>

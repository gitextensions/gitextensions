<?xml version="1.0" encoding="utf-8"?>
<Project>

  <!-- Avalonia/Linux port (see AGENTS.md): allow compiling the Windows-targeting externals
       on non-Windows machines. -->
  <PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>

  <!-- Create a dummy test targets -->
  <Target Name="Test" />
  <Target Name="IntegrationTest" />
  <Target Name="LegacyClean" />
</Project>

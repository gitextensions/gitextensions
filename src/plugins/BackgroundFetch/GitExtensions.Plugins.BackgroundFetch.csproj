<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup Condition="'$(OS)' != 'Windows_NT' or '$(BuildAvalonia)' == 'true'">
    <!-- Avalonia/Linux port: additionally build a cross-platform flavor
         that compiles against GitExtensions.Shims.WinForms instead of real WinForms. -->
    <TargetFramework></TargetFramework>
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <UseWindowsForms Condition="'$(TargetFramework)' == 'net10.0'">false</UseWindowsForms>
    <UseGitExtensionsShims>true</UseGitExtensionsShims>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\app\GitExtUtils\Validates.cs" Link="Validates.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Reactive" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\app\GitCommands\GitCommands.csproj">
      <PrivateAssets>build;buildTransitive;compile</PrivateAssets>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\app\GitExtUtils\GitExtUtils.csproj">
      <PrivateAssets>build;buildTransitive;compile</PrivateAssets>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\..\app\ResourceManager\ResourceManager.csproj">
      <PrivateAssets>build;buildTransitive;compile</PrivateAssets>
      <Private>false</Private>
    </ProjectReference>
    <ProjectReference Include="..\GitUIPluginInterfaces\GitUIPluginInterfaces.csproj">
      <PrivateAssets>build;buildTransitive;compile</PrivateAssets>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup>
    <None Include="Resources\IconBackgroundFetch.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- Resources -->
    <EmbeddedResource Update="Properties\Resources.resx" Generator="ResXFileCodeGenerator" LastGenOutput="Resources.Designer.cs" />
    <Compile Update="Properties\Resources.Designer.cs" AutoGen="True" DependentUpon="Resources.resx" DesignTime="True" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <Compile Remove="$(RepoRoot)\CommonAssemblyInfo.cs" />
    <Compile Remove="Properties\Resources.Designer.cs" />
    <EmbeddedResource Remove="Properties\Resources.resx" />
    <None Remove="Resources\IconBackgroundFetch.png" />
    <Compile Include="..\..\app\GitUI.Avalonia\Properties\CommonAssemblyInfoAvalonia.cs" Link="Properties\CommonAssemblyInfoAvalonia.cs" />
    <EmbeddedResource Include="Resources\IconBackgroundFetch.png" LogicalName="GitExtensions.Plugins.BackgroundFetch.IconBackgroundFetch.png" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net10.0'">
    <Compile Remove="Properties\Resources.NonWindows.cs" />
  </ItemGroup>

</Project>

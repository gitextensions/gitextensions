<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Avalonia/Linux port (see AGENTS.md): additionally build a cross-platform flavor
         that compiles against GitExtensions.Shims.WinForms instead of real WinForms. -->
    <TargetFramework></TargetFramework>
    <TargetFrameworks>net10.0;net10.0-windows</TargetFrameworks>
    <UseWindowsForms Condition="'$(TargetFramework)' == 'net10.0'">false</UseWindowsForms>
    <UseGitExtensionsShims>true</UseGitExtensionsShims>
  </PropertyGroup>
  
  <ItemGroup>
    <Compile Include="..\..\app\GitExtUtils\Validates.cs" Link="Validates.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="JetBrains.Annotations" />
    <PackageReference Include="Microsoft.VisualStudio.Composition" />
    <PackageReference Include="System.Reactive.Interfaces" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\app\GitExtUtils\GitExtUtils.csproj" />
  </ItemGroup>

</Project>

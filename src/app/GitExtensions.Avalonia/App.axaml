<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GitExtensions.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />

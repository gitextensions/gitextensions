<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Avalonia twin of the GitExtensions entry point. -->
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <UseWindowsForms>false</UseWindowsForms>
    <RootNamespace>GitExtensions</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="GitInfo">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GitUI.Avalonia\GitUI.Avalonia.csproj" />
  </ItemGroup>

  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <MacProcessGroupLauncher>$(IntermediateOutputPath)GitExtensions.ProcessGroupLauncher</MacProcessGroupLauncher>
  </PropertyGroup>

  <Target Name="BuildMacProcessGroupLauncher"
          BeforeTargets="CoreCompile"
          Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <MakeDir Directories="$(IntermediateOutputPath)" />
    <Exec Command="cc -std=c11 -Wall -Wextra -Werror -O2 &quot;$(MSBuildProjectDirectory)/Compat/ProcessGroupLauncher.c&quot; -o &quot;$(MacProcessGroupLauncher)&quot;" />
  </Target>

  <Target Name="CopyMacProcessGroupLauncherToOutput"
          AfterTargets="Build"
          DependsOnTargets="BuildMacProcessGroupLauncher"
          Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <Copy SourceFiles="$(MacProcessGroupLauncher)" DestinationFolder="$(TargetDir)" />
  </Target>

  <Target Name="AddMacProcessGroupLauncherToPublish"
          BeforeTargets="ComputeFilesToPublish"
          DependsOnTargets="BuildMacProcessGroupLauncher"
          Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <ItemGroup>
      <ResolvedFileToPublish Include="$(MacProcessGroupLauncher)" RelativePath="GitExtensions.ProcessGroupLauncher" CopyToPublishDirectory="PreserveNewest" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <!-- Cross-platform assemblies must not carry the SupportedOSPlatform("windows7.0")
         attribute from CommonAssemblyInfo.cs; use the platform-neutral variant. -->
    <Compile Remove="$(RepoRoot)\CommonAssemblyInfo.cs" />
    <Compile Include="$(RepoRoot)\src\app\GitUI.Avalonia\Properties\CommonAssemblyInfoAvalonia.cs" Link="Properties\CommonAssemblyInfoAvalonia.cs" />
  </ItemGroup>

</Project>

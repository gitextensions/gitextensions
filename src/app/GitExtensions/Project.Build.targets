<Project>

  <!--
    ============================================================
                       _CopyTranslations

    Copies all available translations to the target directory.
    ============================================================
    -->
  <Target Name="_CopyTranslations" AfterTargets="AfterBuild">
    <_GetAvailableTranslationsCodeTask
          TranslationFolder="$(ProjectDir)\..\GitUI\Translation\">
      <Output ItemName="Translations" TaskParameter="Output"/>
    </_GetAvailableTranslationsCodeTask>

    <Copy SourceFiles="@(Translations)" DestinationFolder="$(TargetDir)Translation" ContinueOnError="false" />
  </Target>

  <!--
    ============================================================
                       _EnumeratePlugins

    Enumerates all available plugins $(TargetDir)\Plugins\$(PluginName) and updates
    app.config with the list of available plugins.

    For the development build all plugins are copied to $(TargetDir)\Plugins\$(PluginName).
    However we need to update probingPath. i.e. where to look for plugins' references.

    ============================================================
    -->
  <Target Name="_EnumeratePlugins" AfterTargets="AfterBuild">

    <ItemGroup>
      <Folders Include="$([System.IO.Directory]::GetDirectories(&quot;$(ArtifactsPluginsDir)&quot;))" />
      <OnlyDirs Include="@(Folders->Replace($(TargetDir), ''))"/>
    </ItemGroup>

    <PropertyGroup>
      <ProbingPrivatePath>Plugins;@(OnlyDirs)</ProbingPrivatePath>
      <TargetAppConfig>@(AppConfigFileDestination)</TargetAppConfig>

      <Namespace>
        <Namespace Prefix="ns" Uri="urn:schemas-microsoft-com:asm.v1" />
      </Namespace>
    </PropertyGroup>

    <XmlPoke XmlInputPath="$(TargetAppConfig.ToString())"
            Namespaces="$(Namespace)"
            Query="configuration/runtime/ns:assemblyBinding/ns:probing/@privatePath" 
            Value="$(ProbingPrivatePath.ToString())" />
  </Target>


  <!--
    ============================================================
                       _UpdateEnglishTranslations

    Extracts translatable strings from source files and updates English*.xlf.
    Runs as part of the project build so it fires correctly in Visual Studio
    (Shift+Ctrl+B) as well as from the command line (dotnet build).
    ============================================================
    -->
  <Target Name="_UpdateEnglishTranslations" AfterTargets="AfterBuild">
    <PropertyGroup>
      <_RepoRoot>$([MSBuild]::NormalizeDirectory('$(SolutionDir)'))</_RepoRoot>
      <_TranslationExtractorProject>$(_RepoRoot)setup\TranslationExtractor\TranslationExtractor.csproj</_TranslationExtractorProject>
      <_TranslationsSourceDir>$([MSBuild]::NormalizeDirectory('$(_RepoRoot)', 'src', 'app', 'GitUI', 'Translation'))</_TranslationsSourceDir>
    </PropertyGroup>

    <Message Text="Extracting translatable strings from source code..." Importance="High" />

    <Exec Command="dotnet run --project &quot;$(_TranslationExtractorProject)&quot; -- &quot;$(_RepoRoot.TrimEnd('\'))&quot; &quot;$(_TranslationsSourceDir.TrimEnd('\'))&quot;"
          WorkingDirectory="$(_RepoRoot)"
          EchoOff="true"
          ConsoleToMsBuild="true"
          StandardOutputImportance="normal">
      <Output TaskParameter="ExitCode" PropertyName="_TranslationExtractorErrorCode" />
    </Exec>
    <Error Text="TranslationExtractor failed with exit code $(_TranslationExtractorErrorCode)"
           Condition="$(_TranslationExtractorErrorCode) != 0" />

    <!-- On CI: verify no changes to English*.xlf -->
    <Exec Command="git -c core.autocrlf=false add *.xlf --ignore-errors"
          IgnoreStandardErrorWarningFormat="true"
          WorkingDirectory="$(_RepoRoot)"
          IgnoreExitCode="true"
          Condition="$(ContinuousIntegrationBuild) == true" />

    <Exec Command="git status --porcelain | findstr /i /r &quot;English.xlf English.Plugins.xlf&quot; "
          WorkingDirectory="$(_RepoRoot)"
          IgnoreExitCode="true"
          ConsoleToMSBuild="true"
          Condition="$(ContinuousIntegrationBuild) == true">
      <Output TaskParameter="ConsoleOutput" PropertyName="_TranslationDiff" />
    </Exec>

    <Message Text="English translations are up-to-date" Importance="High"
             Condition="$(ContinuousIntegrationBuild) == true and '$(_TranslationDiff)' == ''" />
    <Error Text="Please update English translations and re-submit the pull-request. Refer to https://github.com/gitextensions/gitextensions/wiki/Translations"
           Condition="$(ContinuousIntegrationBuild) == true and '$(_TranslationDiff)' != ''" />
  </Target>

</Project>

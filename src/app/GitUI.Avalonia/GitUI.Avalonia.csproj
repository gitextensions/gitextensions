<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Avalonia twin of GitUI: ported types keep their original GitUI
         namespaces so upstream diffs map 1:1 and translation keys stay valid. -->
    <TargetFramework>net10.0</TargetFramework>
    <UseWindowsForms>false</UseWindowsForms>
    <RootNamespace>GitUI</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Ported event handlers keep their WinForms signature "(object sender, EventArgs e)";
         Avalonia's event delegates declare the sender as nullable. -->
    <NoWarn>$(NoWarn);CS8622</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Mirror of the implicit System.Drawing using that UseWindowsForms provides in GitUI,
         so portable GitUI files can be linked below without source changes. Files that also
         use Avalonia's Point/Size alias per file. -->
    <Using Include="System.Drawing" />
  </ItemGroup>

  <ItemGroup>
    <!-- Framework-free GitUI sources compiled unchanged (update
         eng/avalonia/portmap.json when this list changes). -->
    <Compile Include="..\GitExtUtils\Validates.cs" Link="Validates.cs" />
    <Compile Include="..\GitUI\CommandsDialogs\FormClone.RemoteActionResult.cs" Link="CommandsDialogs\FormClone.RemoteActionResult.cs" />
    <Compile Include="..\GitUI\CommandsDialogs\FormRemotesController.cs" Link="CommandsDialogs\FormRemotesController.cs" />
    <Compile Include="..\GitUI\CommandsDialogs\IRevisionGridFileUpdate.cs" Link="CommandsDialogs\IRevisionGridFileUpdate.cs" />

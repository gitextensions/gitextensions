  </ItemGroup>

  <ItemGroup>
    <!-- The language files are shared with the WinForms application; translation keys are
         identical, so all existing translations apply to the Avalonia twins unchanged. -->
    <None Include="..\GitUI\Translation\*.xlf" Link="Translation\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
    <!-- Images.resx's existing file-backed assets. Properties/Images.g.cs exposes the same
         property names as the WinForms resource designer and loads these packaged PNGs. -->
    <AvaloniaResource Include="..\GitUI\Resources\Backgrounds\*.png" Link="Resources\Backgrounds\%(Filename)%(Extension)" />
    <AvaloniaResource Include="..\GitUI\Resources\Help\*.png" Link="Resources\Help\%(Filename)%(Extension)" />
    <AvaloniaResource Include="..\GitUI\Resources\Icons\*.png" Link="Resources\Icons\%(Filename)%(Extension)" />
    <AvaloniaResource Include="..\GitUI\Resources\Icons\*.ico" Link="Resources\Icons\%(Filename)%(Extension)" />
    <AvaloniaResource Include="..\..\..\setup\assets\Logo\*.png" Link="Resources\Logo\%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.AvaloniaEdit" />
    <PackageReference Include="Avalonia.Controls.ColorPicker" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="JetBrains.Annotations" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\GitCommands\GitCommands.csproj" />
    <ProjectReference Include="..\GitExtensions.Extensibility\GitExtensions.Extensibility.csproj" />
    <ProjectReference Include="..\GitExtensions.Shims.WinForms\GitExtensions.Shims.WinForms.csproj" />
    <ProjectReference Include="..\GitExtUtils\GitExtUtils.csproj" />
    <ProjectReference Include="..\ResourceManager\ResourceManager.csproj" />
    <ProjectReference Include="..\..\plugins\GitUIPluginInterfaces\GitUIPluginInterfaces.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Cross-platform assemblies must not carry the SupportedOSPlatform("windows7.0")
         attribute from CommonAssemblyInfo.cs; use the platform-neutral variant. -->
    <Compile Remove="$(RepoRoot)\CommonAssemblyInfo.cs" />
  </ItemGroup>

</Project>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GitUI.FileStatusList">
  <DockPanel>
    <TextBlock DockPanel.Dock="Top" x:Name="lblCount" Margin="4,2" Opacity="0.7" />
    <ListBox x:Name="lstFiles" SelectionMode="Single" />
  </DockPanel>
</UserControl>

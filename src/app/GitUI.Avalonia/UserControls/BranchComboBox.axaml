<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:compat="using:GitUI.Compat"
             xmlns:properties="using:GitUI.Properties"
             x:Class="GitUI.BranchComboBox"
             MinHeight="26">
  <Grid ColumnDefinitions="*,Auto" ColumnSpacing="4">
    <ComboBox x:Name="branches"
              IsEditable="True"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Center" />
    <compat:IconButton x:Name="selectMultipleBranchesButton"
                       Classes="gitextensions-icon-only"
                       Grid.Column="1"
                       Width="27"
                       MinHeight="24"
                       Padding="2"
                       Icon="{x:Static properties:Images.SelectBranch}" />
  </Grid>
</UserControl>

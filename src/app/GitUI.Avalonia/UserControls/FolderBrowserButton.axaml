<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:compat="using:GitUI.Compat"
             xmlns:properties="using:GitUI.Properties"
             x:Class="GitUI.UserControls.FolderBrowserButton">
  <compat:IconButton x:Name="buttonBrowse"
                     Icon="{x:Static properties:Images.BrowseFileExplorer}"
                     Content="_Browse..."
                     HorizontalAlignment="Stretch"
                     HorizontalContentAlignment="Center" />
</UserControl>

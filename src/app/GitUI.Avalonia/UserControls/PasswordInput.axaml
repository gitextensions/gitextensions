<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GitUI.UserControls.PasswordInput">
  <Grid ColumnDefinitions="*,Auto,Auto">
    <TextBox x:Name="Password" Margin="4" MinWidth="100" PasswordChar="●" />
    <!-- TODO(avalonia-port): eye image like WinForms once image resources are ported. -->
    <Button x:Name="ShowPassword" Grid.Column="1" Margin="0,3,3,3" Content="👁" />
    <Button x:Name="SendInput" Grid.Column="2" Margin="0,3,3,3" Content="Send input" />
  </Grid>
</UserControl>

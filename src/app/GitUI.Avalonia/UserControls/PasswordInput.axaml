<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:compat="using:GitUI.Compat"
             xmlns:properties="using:GitUI.Properties"
             x:Class="GitUI.UserControls.PasswordInput">
  <Grid ColumnDefinitions="*,Auto,Auto">
    <TextBox x:Name="Password" Margin="4" MinWidth="100" PasswordChar="●" />
    <compat:IconButton x:Name="ShowPassword"
                       Classes="gitextensions-icon-only"
                       Grid.Column="1"
                       Margin="0,3,3,3"
                       Icon="{x:Static properties:Images.EyeClosed}" />
    <Button x:Name="SendInput" Grid.Column="2" Margin="0,3,3,3" Content="Send input" />
  </Grid>
</UserControl>

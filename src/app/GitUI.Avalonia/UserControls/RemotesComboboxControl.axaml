<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:compat="using:GitUI.Compat"
             xmlns:properties="using:GitUI.Properties"
             x:Class="GitUI.UserControls.RemotesComboboxControl"
             MinWidth="181"
             MinHeight="25">
  <Grid x:Name="tableLayoutPanel1"
        ColumnDefinitions="*,Auto">
    <ComboBox x:Name="comboBoxRemotes"
              HorizontalAlignment="Stretch"
              IsEditable="True" />
    <compat:IconButton x:Name="buttonSelectMultipleRemotes"
                       Classes="gitextensions-icon-only"
                       Grid.Column="1"
                       Width="26"
                       Margin="4,0,0,0"
                       Icon="{x:Static properties:Images.SelectBranch}"
                       IsVisible="False" />
  </Grid>
</UserControl>

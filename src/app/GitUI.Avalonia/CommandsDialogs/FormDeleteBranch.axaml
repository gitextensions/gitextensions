<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gitui="clr-namespace:GitUI"
        x:Class="GitUI.CommandsDialogs.FormDeleteBranch"
        Width="500" Height="150"
        MinWidth="420" MinHeight="130"
        MaxWidth="950" MaxHeight="180"
        WindowStartupLocation="CenterOwner"
        Title="Delete branch">
  <DockPanel>
    <StackPanel x:Name="ControlsPanel"
                DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="10,8">
      <Button x:Name="Delete"
              MinWidth="75"
              Content="_Delete"
              IsDefault="True" />
    </StackPanel>

    <Grid x:Name="MainPanel"
          Margin="12"
          ColumnDefinitions="Auto,*"
          ColumnSpacing="10">
      <Label x:Name="labelSelectBranches"
             Padding="0"
             Content="Select _branches"
             Target="{Binding #Branches}"
             VerticalAlignment="Center" />
      <gitui:BranchComboBox x:Name="Branches"
                            Grid.Column="1"
                            MinWidth="260" />
    </Grid>
  </DockPanel>
</Window>

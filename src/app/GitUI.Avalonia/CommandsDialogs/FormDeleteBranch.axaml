<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gitui="clr-namespace:GitUI"
        x:Class="GitUI.CommandsDialogs.FormDeleteBranch"
        Width="500" Height="150"
        MinWidth="420" MinHeight="130"
        MaxWidth="950" MaxHeight="180"
        WindowStartupLocation="CenterOwner"
        Title="Delete branch">
  <DockPanel>
    <StackPanel x:Name="ControlsPanel"
                Classes="gitextensions-dialog-controls"
                DockPanel.Dock="Bottom"
                Spacing="8"
                Margin="10,8">
      <Button x:Name="Delete"
              Classes="gitextensions-dialog-action"
              Content="_Delete"
              IsDefault="True" />
    </StackPanel>

    <Grid x:Name="MainPanel"
          Classes="gitextensions-dialog-main"
          Margin="9"
          ColumnDefinitions="Auto,*"
          ColumnSpacing="10">
      <Label x:Name="labelSelectBranches"
             Classes="gitextensions-dialog-label"
             Padding="0"
             Content="Select _branches"
             Target="{Binding #Branches}" />
      <gitui:BranchComboBox x:Name="Branches"
                            Grid.Column="1"
                            MinWidth="260" />
    </Grid>
  </DockPanel>
</Window>

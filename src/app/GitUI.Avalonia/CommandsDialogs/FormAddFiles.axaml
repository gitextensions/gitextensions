<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GitUI.CommandsDialogs.FormAddFiles"
        Width="570"
        Height="120"
        MinWidth="570"
        MinHeight="120"
        MaxHeight="120"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="Add files">
  <Grid Classes="gitextensions-dialog-main"
        RowDefinitions="Auto,Auto"
        ColumnDefinitions="Auto,*,Auto,Auto"
        RowSpacing="8"
        ColumnSpacing="8">
    <Label x:Name="label1"
           Content="Filter"
           Target="{Binding #Filter}"
           VerticalAlignment="Center" />
    <TextBox x:Name="Filter"
             Grid.Column="1"
             Text="." />
    <Button x:Name="ShowFiles"
            Classes="gitextensions-dialog-action"
            Grid.Column="2"
            MinWidth="94"
            Content="Show files" />
    <Button x:Name="AddFiles"
            Classes="gitextensions-dialog-action"
            Grid.Column="3"
            MinWidth="94"
            Content="Add files"
            IsDefault="True" />
    <CheckBox x:Name="force"
              Grid.Row="1"
              Grid.Column="1"
              Content="Force" />
  </Grid>
</Window>

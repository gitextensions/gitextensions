<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="using:GitUI.Help"
        x:Class="GitUI.CommandsDialogs.FormRebase"
        Width="1034"
        Height="500"
        MinWidth="850"
        MinHeight="430"
        WindowStartupLocation="CenterOwner"
        Title="Rebase">
  <Grid RowDefinitions="*,Auto,Auto">
    <Border x:Name="MainPanel" Padding="9">
      <Grid x:Name="MainLayout" ColumnDefinitions="Auto,*" ColumnSpacing="8">
        <help:HelpImageDisplayUserControl x:Name="PanelLeftImage"
                                          MinHeight="390"
                                          IsExpanded="True"
                                          UniqueIsExpandedSettingsId="Rebase" />

        <Grid x:Name="PanelMiddle"
              Grid.Column="1"
              RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto"
              RowSpacing="8">
          <TextBlock x:Name="lblRebase"
                     Text="Rebase current branch on top of another branch" />

          <StackPanel x:Name="PanelCurrentBranch"
                      Grid.Row="1"
                      Orientation="Horizontal"
                      Spacing="6">
            <TextBlock x:Name="lblCurrent" Text="Current branch:" />
            <TextBlock x:Name="Currentbranch" FontWeight="Bold" />
          </StackPanel>

          <StackPanel x:Name="rebasePanel"
                      Grid.Row="2"
                      Orientation="Horizontal"
                      Spacing="8">
            <Label x:Name="label2"
                   Content="_Rebase on"
                   Target="{Binding #cboBranches}"
                   VerticalAlignment="Center" />
            <ComboBox x:Name="cboBranches"
                      Width="300"
                      IsEditable="True" />
            <HyperlinkButton x:Name="llblShowOptions"
                             VerticalAlignment="Center"
                             Content="Show options" />
          </StackPanel>

          <WrapPanel x:Name="flpnlOptionsPanelTop"
                     Grid.Row="3"
                     IsVisible="False">
            <CheckBox x:Name="chkInteractive"
                      Margin="0,0,10,4"
                      Content="_Interactive Rebase"
                      IsVisible="False" />
            <CheckBox x:Name="chkPreserveMerges"
                      Margin="0,0,10,4"
                      Content="_Preserve Merges" />
            <CheckBox x:Name="chkAutosquash"
                      Margin="0,0,10,4"
                      Content="Autos_quash"
                      IsVisible="False"
                      IsEnabled="False" />
            <CheckBox x:Name="chkStash"
                      Margin="0,0,10,4"
                      Content="A_uto stash"
                      IsEnabled="False" />
            <CheckBox x:Name="chkIgnoreDate"
                      Margin="0,0,10,4"
                      Content="Ignore _date" />
            <CheckBox x:Name="chkCommitterDateIsAuthorDate"
                      Margin="0,0,10,4"
                      Content="Co_mmitter date is author date" />
            <CheckBox x:Name="checkBoxUpdateRefs"
                      Margin="0,0,10,4"
                      Content="Update dependent r_efs" />
          </WrapPanel>

          <StackPanel x:Name="flpnlOptionsPanelBottom"
                      Grid.Row="4"
                      Orientation="Horizontal"
                      Spacing="6"
                      IsVisible="False">
            <CheckBox x:Name="chkSpecificRange"
                      Content="Specific ra_nge" />
            <Label x:Name="lblRangeFrom"
                   Content="_From (exc.)"
                   Target="{Binding #txtFrom}"
                   VerticalAlignment="Center" />
            <TextBox x:Name="txtFrom"
                     Width="100"
                     IsEnabled="False" />
            <Button x:Name="btnChooseFromRevision"
                    Width="26"
                    Content="…"
                    IsVisible="False"
                    IsEnabled="False" />
            <Label x:Name="lblRangeTo"
                   Content="_To"
                   Target="{Binding #cboTo}"
                   VerticalAlignment="Center" />
            <ComboBox x:Name="cboTo"
                      Width="200"
                      IsEditable="True"
                      IsEnabled="False" />
          </StackPanel>

          <!-- PatchGrid belongs to interactive rebase visualization and is retained only
               as a named layout placeholder until that control is ported. -->
          <TextBlock x:Name="lblCommitsToReapply"
                     Grid.Row="5"
                     Text="Commits to re-apply:"
                     IsVisible="False" />
          <Border x:Name="PatchGrid"
                  Grid.Row="5"
                  IsVisible="False" />

          <Grid x:Name="tlpnlSecondaryControls"
                Grid.Row="6"
                ColumnDefinitions="*,*">
            <StackPanel x:Name="flowLayoutPanel1"
                        Orientation="Horizontal"
                        Spacing="6">
              <Button x:Name="btnAddFiles"
                      MinWidth="79"
                      Content="_Add files"
                      IsVisible="False" />
              <Button x:Name="btnCommit"
                      MinWidth="86"
                      Content="C_ommit..."
                      IsVisible="False" />
              <Button x:Name="btnEditTodo"
                      MinWidth="90"
                      Content="_Edit todo..."
                      IsVisible="False" />
            </StackPanel>
            <StackPanel x:Name="flowLayoutPanel2"
                        Grid.Column="1"
                        HorizontalAlignment="Right">
              <Button x:Name="btnSkip"
                      MinWidth="183"
                      Content="S_kip currently applying commit"
                      IsVisible="False" />
            </StackPanel>
          </Grid>
        </Grid>
      </Grid>
    </Border>

    <StackPanel x:Name="ControlsPanel"
                Grid.Row="1"
                Margin="8"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="6">
      <Button x:Name="btnRebase"
              MinWidth="100"
              Content="Rebase"
              IsDefault="True" />
      <Border x:Name="MergeToolPanel">
        <Button x:Name="btnSolveConflicts"
                MinWidth="110"
                Content="_Solve conflicts"
                IsVisible="False" />
      </Border>
      <Button x:Name="btnContinueRebase"
              MinWidth="115"
              Content="_Continue rebase"
              IsVisible="False" />
      <Button x:Name="btnAbort"
              MinWidth="75"
              Content="A_bort"
              IsVisible="False" />
    </StackPanel>

    <Button x:Name="btnSolveMergeconflicts"
            Grid.Row="2"
            Margin="12,0,12,8"
            MinWidth="213"
            HorizontalAlignment="Left"
            Content="There are unresolved merge conflicts"
            IsVisible="False" />
  </Grid>
</Window>

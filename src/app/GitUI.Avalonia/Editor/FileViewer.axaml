<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avaloniaEdit="https://github.com/avaloniaui/avaloniaedit"
             x:Class="GitUI.Editor.FileViewer">
  <avaloniaEdit:TextEditor x:Name="TextEditor"
                           Classes="gitextensions-diff-editor"
                           IsReadOnly="True"
                           ShowLineNumbers="True"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto">
    <avaloniaEdit:TextEditor.ContextMenu>
      <ContextMenu x:Name="contextMenu">
        <MenuItem x:Name="copyToolStripMenuItem"
                  Header="_Copy"
                  InputGesture="Ctrl+C" />
        <Separator x:Name="toolStripSeparator1" />
        <MenuItem x:Name="findToolStripMenuItem"
                  Header="_Find..."
                  InputGesture="Ctrl+F" />
        <MenuItem x:Name="replaceToolStripMenuItem"
                  Header="_Replace..."
                  InputGesture="Ctrl+H"
                  IsVisible="False" />
        <MenuItem x:Name="goToLineToolStripMenuItem"
                  Header="_Go to line"
                  InputGesture="Ctrl+G" />
      </ContextMenu>
    </avaloniaEdit:TextEditor.ContextMenu>
  </avaloniaEdit:TextEditor>
</UserControl>

<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="GitExtensionsSelectionBackgroundBrush"
                           Color="#0078D4" />
          <SolidColorBrush x:Key="GitExtensionsSelectionPointerOverBackgroundBrush"
                           Color="#106EBE" />
          <SolidColorBrush x:Key="GitExtensionsSelectionForegroundBrush"
                           Color="#FFFFFF" />
          <SolidColorBrush x:Key="GitExtensionsInactiveSelectionBackgroundBrush"
                           Color="#E6E6E6" />
          <SolidColorBrush x:Key="GitExtensionsSectionBorderBrush"
                           Color="#D2D2D2" />
          <SolidColorBrush x:Key="GitExtensionsSplitterBrush"
                           Color="#A6A6A6" />
          <SolidColorBrush x:Key="GitExtensionsRefLabelBackgroundBrush"
                           Color="#FFFFFF" />
          <SolidColorBrush x:Key="GitExtensionsBranchRefBrush"
                           Color="#008000" />
          <SolidColorBrush x:Key="GitExtensionsRemoteBranchRefBrush"
                           Color="#8B0009" />
          <SolidColorBrush x:Key="GitExtensionsTagRefBrush"
                           Color="#00008B" />
          <SolidColorBrush x:Key="GitExtensionsOtherRefBrush"
                           Color="#808080" />
          <SolidColorBrush x:Key="GitExtensionsTreeConnectorBrush"
                           Color="#8A8A8A" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="GitExtensionsSelectionBackgroundBrush"
                           Color="#0067C0" />
          <SolidColorBrush x:Key="GitExtensionsSelectionPointerOverBackgroundBrush"
                           Color="#1473E6" />
          <SolidColorBrush x:Key="GitExtensionsSelectionForegroundBrush"
                           Color="#FFFFFF" />
          <SolidColorBrush x:Key="GitExtensionsInactiveSelectionBackgroundBrush"
                           Color="#3A3A3A" />
          <SolidColorBrush x:Key="GitExtensionsSectionBorderBrush"
                           Color="#4C4C4C" />
          <SolidColorBrush x:Key="GitExtensionsSplitterBrush"
                           Color="#686868" />
          <SolidColorBrush x:Key="GitExtensionsRefLabelBackgroundBrush"
                           Color="#202020" />
          <SolidColorBrush x:Key="GitExtensionsBranchRefBrush"
                           Color="#7FE28A" />
          <SolidColorBrush x:Key="GitExtensionsRemoteBranchRefBrush"
                           Color="#FD9797" />
          <SolidColorBrush x:Key="GitExtensionsTagRefBrush"
                           Color="#40BAF7" />
          <SolidColorBrush x:Key="GitExtensionsOtherRefBrush"
                           Color="#CFB3B3" />
          <SolidColorBrush x:Key="GitExtensionsTreeConnectorBrush"
                           Color="#7A7A7A" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Styles.Resources>

  <!-- Keep these colors behind semantic resources. A future theme service can derive the
       palette from the desktop accent while preserving contrast for graph and ref colors. -->
  <Style Selector="ListBoxItem">
    <Setter Property="MinHeight" Value="24" />
    <Setter Property="Padding" Value="6,2" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSelectionBackgroundBrush}" />
    <Setter Property="Foreground"
            Value="{DynamicResource GitExtensionsSelectionForegroundBrush}" />
  </Style>
  <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSelectionPointerOverBackgroundBrush}" />
  </Style>

  <Style Selector="TreeViewItem">
    <Setter Property="MinHeight" Value="24" />
  </Style>
  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSelectionBackgroundBrush}" />
  </Style>
  <Style Selector="TreeViewItem:selected /template/ ContentPresenter#PART_HeaderPresenter">
    <Setter Property="Foreground"
            Value="{DynamicResource GitExtensionsSelectionForegroundBrush}" />
  </Style>
  <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSelectionPointerOverBackgroundBrush}" />
  </Style>

  <Style Selector="Border.gitextensions-tree-connector">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsTreeConnectorBrush}" />
  </Style>

  <Style Selector="GridSplitter">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSplitterBrush}" />
  </Style>
  <Style Selector="Border.gitextensions-section">
    <Setter Property="BorderBrush"
            Value="{DynamicResource GitExtensionsSectionBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="Border.gitextensions-section-separator">
    <Setter Property="Background"
            Value="{DynamicResource GitExtensionsSectionBorderBrush}" />
  </Style>
</Styles>
